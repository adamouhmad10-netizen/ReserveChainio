# ======================================================================
# ReserveChain.io — environment variable template
# No real secret may be committed. Copy to .env.local per environment.
# ======================================================================

# ---- Application ----
# development | staging | production  (staging must never be indexed)
RC_ENVIRONMENT=development
# Website mode: development | pre-launch | waitlist | documentation-release |
# asset-verification | eligibility | early-participation | live-offering |
# redemption | enterprise-onboarding
# Only development / pre-launch / waitlist may be enabled without written
# issuer authorization. Live modes never auto-activate.
RC_WEBSITE_MODE=pre-launch
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Database ----
# Demo build uses an embedded SQLite file (auto-created). Production target is
# PostgreSQL (Supabase or equivalent) — see docs/database-schema.md.
RC_SQLITE_PATH=./data/reservechain.db
# DATABASE_URL=postgresql://user:pass@host:5432/reservechain
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only, never exposed to the client

# ---- Auth / sessions ----
# 64+ char random string used to sign admin session cookies (demo auth layer).
RC_SESSION_SECRET=change-me-generate-a-long-random-string
# Demo admin bootstrap credentials (created on first run; change immediately).
RC_DEMO_ADMIN_EMAIL=admin@reservechain.local
RC_DEMO_ADMIN_PASSWORD=change-me-strong-password

# ---- Email (transactional / waitlist verification) ----
# PENDING THIRD PARTY: no provider account exists yet. Verification emails are
# generated and stored but not dispatched until these are configured.
# EMAIL_PROVIDER=            # e.g. postmark | ses | resend
# EMAIL_API_KEY=
# EMAIL_FROM=no-reply@reservechain.io

# ---- Ethereum / contracts (testnet only — Mainnet requires written authorization) ----
# ETH_NETWORK=sepolia
# SEPOLIA_RPC_URL=
# DEPLOYER_PRIVATE_KEY=      # NEVER commit. Use a secrets manager / hardware wallet.
# ETHERSCAN_API_KEY=

# ---- Compliance provider adapters (PENDING THIRD PARTY / owner selection) ----
# KYC_PROVIDER=
# KYC_API_KEY=
# SANCTIONS_PROVIDER=
# SANCTIONS_API_KEY=
# CHAIN_ANALYTICS_PROVIDER=
# CHAIN_ANALYTICS_API_KEY=

# ---- Monitoring / analytics (consent-gated; PENDING THIRD PARTY) ----
# SENTRY_DSN=
# ANALYTICS_ID=

# ---- Feature flags (all financial modules ship disabled) ----
RC_MODULE_TOKEN_ACQUISITION=disabled
RC_MODULE_WALLET_CONNECT=disabled
RC_MODULE_PROOF_OF_RESERVES_PUBLIC=disabled
RC_MODULE_REDEMPTION=disabled
RC_MODULE_INVESTOR_PORTAL=disabled
